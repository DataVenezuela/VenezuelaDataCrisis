# Copiar a .env (gitignored) y ajustar. NO commitear secretos reales.

# Credenciales del contenedor Postgres local (docker-compose).
POSTGRES_USER=vzla
POSTGRES_PASSWORD=vzla_local_dev
POSTGRES_DB=vzla_dedup
POSTGRES_PORT=5432

# DSN que usa la app. Local apunta al contenedor.
# Producción: reemplazar por el DATABASE_URL que entrega Supabase.
DATABASE_URL=postgresql://vzla:vzla_local_dev@localhost:5432/vzla_dedup

# Secreto HMAC para tokenizar identidad (cedula_hmac). Cambiar por uno real y secreto.
PII_HMAC_SECRET=cambiar-esto-por-secreto-real
