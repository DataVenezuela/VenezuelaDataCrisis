digraph pipeline {
    // ── Global ────────────────────────────────────────────────────────────
    rankdir     = TB
    newrank     = true
    fontname    = "Helvetica Neue, Arial, sans-serif"
    fontsize    = 12
    bgcolor     = "#ffffff"
    splines     = ortho
    nodesep     = 0.55
    ranksep     = 0.70
    pad         = 0.6

    node [
        fontname  = "Helvetica Neue, Arial, sans-serif"
        fontsize  = 11
        shape     = box
        style     = "rounded,filled"
        margin    = "0.22,0.14"
        penwidth  = 1.4
    ]

    edge [
        color    = "#888888"
        arrowsize = 0.75
        penwidth = 1.3
    ]

    // ── 1. FUENTES ────────────────────────────────────────────────────────
    subgraph cluster_sources {
        label     = "Fuentes"
        labelloc  = t
        style     = "rounded,dashed"
        color     = "#b0a89a"
        bgcolor   = "#fafaf7"
        fontname  = "Helvetica Neue, Arial, sans-serif"
        fontsize  = 11
        fontcolor = "#5c5448"
        margin    = 14

        node [fillcolor="#f5f0e8" color="#c9c0ab" fontcolor="#333333"]

        s_webapp [label=<<B>WebApp JS</B>>]
        s_html   [label=<<B>HTML estático</B>>]
        s_api    [label=<<B>API / JSON</B>>]
        s_pdf    [label=<<B>PDF / manual</B>>]

        { rank=same; s_webapp; s_html; s_api; s_pdf }
    }

    // ── 2. ADAPTERS ───────────────────────────────────────────────────────
    subgraph cluster_adapters {
        label     = "Adapters"
        labelloc  = t
        style     = "rounded,dashed"
        color     = "#7c6fc4"
        bgcolor   = "#f5f4fc"
        fontname  = "Helvetica Neue, Arial, sans-serif"
        fontsize  = 11
        fontcolor = "#3d2e8a"
        margin    = 14

        node [fillcolor="#e8e4f8" color="#7c6fc4" fontcolor="#3d2e8a"]

        a_playwright [label=<<B>Playwright</B>>]
        a_bs4        [label=<<B>BeautifulSoup</B>>]
        a_httpx      [label=<<B>httpx</B>>]
        a_pdf        [label=<<B>pdfplumber</B>>]

        { rank=same; a_playwright; a_bs4; a_httpx; a_pdf }
    }

    // ── 3. PARSERS ────────────────────────────────────────────────────────
    subgraph cluster_parsers {
        label     = "Parsers (uno por fuente)"
        labelloc  = t
        style     = "rounded,dashed"
        color     = "#c05a50"
        bgcolor   = "#fef6f5"
        fontname  = "Helvetica Neue, Arial, sans-serif"
        fontsize  = 11
        fontcolor = "#7a2a22"
        margin    = 14

        node [fillcolor="#fde8e4" color="#d4665a" fontcolor="#8b2020"]

        p_encuentralos [label=<<B>encuentralos</B><BR/><FONT POINT-SIZE="9.5" COLOR="#b94a3a">→ Person</FONT>>]
        p_veneconnect  [label=<<B>veneconnect</B><BR/><FONT POINT-SIZE="9.5" COLOR="#b94a3a">→ AcopioCenter</FONT>>]
        p_usgs         [label=<<B>usgs</B><BR/><FONT POINT-SIZE="9.5" COLOR="#b94a3a">→ Event</FONT>>]
        p_nmas         [label=<<FONT POINT-SIZE="10" COLOR="#999999">+ N más</FONT>>, style="rounded,filled", fillcolor="#fdf4f2", color="#e0b0aa", fontcolor="#999999"]

        { rank=same; p_encuentralos; p_veneconnect; p_usgs; p_nmas }
    }

    // ── 4. MODELOS TIPADOS ────────────────────────────────────────────────
    subgraph cluster_models {
        label     = "Modelos tipados"
        labelloc  = t
        style     = "rounded,dashed"
        color     = "#3bab8e"
        bgcolor   = "#f0faf7"
        fontname  = "Helvetica Neue, Arial, sans-serif"
        fontsize  = 11
        fontcolor = "#1a5c48"
        margin    = 14

        node [fillcolor="#d6f5ef" color="#3bab8e" fontcolor="#1a5c48"]

        m_person  [label=<<B>Person</B>>]
        m_acopio  [label=<<B>AcopioCenter</B>>]
        m_event   [label=<<B>Event</B>>]

        { rank=same; m_person; m_acopio; m_event }
    }

    // ── 5. LIMPIEZA COMPARTIDA ────────────────────────────────────────────
    subgraph cluster_cleaning {
        label     = "Limpieza compartida"
        labelloc  = t
        style     = "rounded,dashed"
        color     = "#aad4c8"
        bgcolor   = "#f5fdf9"
        fontname  = "Helvetica Neue, Arial, sans-serif"
        fontsize  = 11
        fontcolor = "#2d7a64"
        margin    = 18

        subgraph cluster_modules {
            label     = "Módulos reutilizables"
            labelloc  = t
            style     = "rounded,dashed"
            color     = "#c0ddd6"
            bgcolor   = "#edf9f5"
            fontname  = "Helvetica Neue, Arial, sans-serif"
            fontsize  = 10
            fontcolor = "#3d7a68"
            margin    = 12

            node [fillcolor="#d6f5ef" color="#3bab8e" fontcolor="#1a5c48"]

            c_pii    [label=<<B>PII</B><BR/><FONT POINT-SIZE="9" COLOR="#3a8a72">redact + HMAC</FONT>>]
            c_norm   [label=<<B>Normalizar</B><BR/><FONT POINT-SIZE="9" COLOR="#3a8a72">texto + fechas</FONT>>]
            c_dedup  [label=<<B>Dedup</B><BR/><FONT POINT-SIZE="9" COLOR="#3a8a72">fingerprint + fuzzy</FONT>>]
            c_valid  [label=<<B>Validar</B><BR/><FONT POINT-SIZE="9" COLOR="#3a8a72">quality score</FONT>>]

            { rank=same; c_pii; c_norm; c_dedup; c_valid }
        }
    }

    // ── 6. EXPORT ─────────────────────────────────────────────────────────
    subgraph cluster_export {
        label     = "Export"
        labelloc  = t
        style     = "rounded,dashed"
        color     = "#3bab8e"
        bgcolor   = "#f0faf7"
        fontname  = "Helvetica Neue, Arial, sans-serif"
        fontsize  = 11
        fontcolor = "#1a5c48"
        margin    = 14

        node [fillcolor="#d6f5ef" color="#3bab8e" fontcolor="#1a5c48"]

        e_persons [label=<<B>persons.jsonl</B>>]
        e_acopio  [label=<<B>acopio.jsonl</B>>]
        e_events  [label=<<B>events.jsonl</B>>]

        { rank=same; e_persons; e_acopio; e_events }
    }

    // ── 7. DB / API ───────────────────────────────────────────────────────
    db [
        label    = <<B>DB / API</B>>
        shape    = box
        style    = "rounded,filled"
        fillcolor = "#f5f0e8"
        color    = "#c9c0ab"
        fontcolor = "#333333"
        fontsize  = 12
        width    = 3.2
        height   = 0.5
    ]

    // ── ARISTAS ───────────────────────────────────────────────────────────

    // Fuentes → Adapters (columna a columna)
    s_webapp -> a_playwright
    s_html   -> a_bs4
    s_api    -> a_httpx
    s_pdf    -> a_pdf

    // Adapters → Parsers (converge en los 3 parsers principales)
    a_playwright -> p_encuentralos
    a_bs4        -> p_veneconnect
    a_httpx      -> p_usgs
    a_pdf        -> p_nmas [style=dashed, color="#cccccc"]

    // Parsers → Modelos
    p_encuentralos -> m_person
    p_veneconnect  -> m_acopio
    p_usgs         -> m_event

    // Modelos → Limpieza (todos convergen al cluster de limpieza, representado por c_pii)
    m_person -> c_pii  [ltail=cluster_models, lhead=cluster_cleaning]
    m_acopio -> c_norm [style=invis]
    m_event  -> c_dedup [style=invis]

    // Limpieza → Export
    c_pii   -> e_persons [ltail=cluster_cleaning]
    c_norm  -> e_acopio  [style=invis]
    c_dedup -> e_events  [style=invis]
    c_valid -> e_persons [style=invis]

    // Export → DB / API
    e_persons -> db
    e_acopio  -> db
    e_events  -> db

    // Cluster edges habilitados
    compound = true
}
